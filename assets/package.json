{
  "name": "lisp",
  "version": "1.0.0",
  "description": "https://justine.lol/sectorlisp/ in https://www.assemblyscript.org/",
  "scripts": {
    "asbuild:lisp": "npx -y --package assemblyscript asc --config ../lisp/asconfig.json ../lisp/assembly/index.ts -o lisp.wasm --target release",
    "asbuild:TinyBasic": "npx -y --package assemblyscript asc --config ../TinyBasic/asconfig.json ../TinyBasic/assembly/index.ts -o TinyBasic.wasm --target release",
    "build": "npx -y --package tsdown --package typescript@^6.0.3 tsdown"
  },
  "author": "Jan Burgy",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@xterm/xterm": "^6.0.0",
    "xterm-pty": "^0.12.0"
  }
}
